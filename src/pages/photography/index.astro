---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortItemsByDateDesc } from '../../utils/data-utils';

const photos = (await getCollection('photography')).sort(sortItemsByDateDesc);
---

<BaseLayout title="Photography" description="A visual journal — concert halls, landscapes, and the quiet moments between." showHeader={false}>
    <div class="mb-16 sm:mb-24">
        <h1 class="mb-4 font-serif text-2xl leading-tight italic sm:text-4xl">Photography</h1>
        <p class="text-sm opacity-70 mb-12 sm:mb-16">A visual journal — concert halls, landscapes, and the quiet moments between.</p>

        <div class="photo-grid">
            {photos.map((photo) => (
                <article class="photo-item group">
                    <div class="photo-frame overflow-hidden">
                        <Image
                            src={photo.data.coverImage.src}
                            alt={photo.data.coverImage.alt ?? photo.data.title}
                            width={800}
                            height={600}
                            class="photo-img w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                            loading="lazy"
                        />
                    </div>
                    <div class="mt-3">
                        <h2 class="font-serif text-base italic leading-snug group-hover:text-[#ffcc55] transition-colors">
                            {photo.data.title}
                        </h2>
                        {photo.data.location && (
                            <p class="mt-0.5 font-sans text-xs tracking-widest uppercase opacity-50">{photo.data.location}</p>
                        )}
                        {photo.data.description && (
                            <p class="mt-1 text-sm opacity-70 leading-snug">{photo.data.description}</p>
                        )}
                    </div>
                </article>
            ))}
        </div>
    </div>
</BaseLayout>

<style>
    .photo-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
    }

    @media (max-width: 640px) {
        .photo-grid {
            grid-template-columns: 1fr;
            gap: 2.5rem;
        }
    }

    /* Stagger heights for a natural, gallery feel */
    .photo-frame {
        aspect-ratio: 4 / 3;
        background-color: var(--bg-muted);
    }

    .photo-item:nth-child(3n + 2) .photo-frame {
        aspect-ratio: 3 / 4;
    }

    .photo-item:nth-child(4n + 3) .photo-frame {
        aspect-ratio: 16 / 9;
    }
</style>
