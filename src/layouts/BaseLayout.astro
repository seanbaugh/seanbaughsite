---
import { ClientRouter } from 'astro:transitions';
import BaseHead, { type Props as HeadProps } from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';

export type Props = HeadProps & { showHeader?: boolean };

const { showHeader = true, ...head } = Astro.props;
---

<!doctype html>
<html lang="en" class="wrap-break-words antialiased">
    <head>
        <BaseHead {...head} />
        <script>
            if (localStorage.theme === 'light') {
                document.documentElement.classList.add('light');
            }
        </script>
        <ClientRouter />
        <script is:inline src="/theme-toggle.js"></script>
    </head>
    <body class="bg-main text-main relative">
        <!-- Geometric pattern overlay -->
        <div class="geo-pattern" aria-hidden="true"></div>
        <div class="flex min-h-screen flex-col px-4 md:px-8 relative z-10">
            <Nav />
            {showHeader && <Header />}
            <main class="mx-auto w-full max-w-3xl grow">
                <slot />
            </main>
            <Footer />
        </div>
    </body>
</html>

<style>
    .geo-pattern {
        position: fixed;
        inset: 0;
        z-index: 0;
        background-image: url('/pattern.svg');
        background-repeat: repeat;
        pointer-events: none;
        opacity: 1;
    }
</style>
