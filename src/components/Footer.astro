---
import siteConfig from '../data/site-config';

const socialLinks = siteConfig.socialLinks ?? [];
const navLinks = siteConfig.footerNavLinks ?? [];
const currentYear = new Date().getFullYear();
---

<footer class="mx-auto w-full max-w-3xl pt-12 pb-10 sm:pt-20 sm:pb-14">
    <div class="border-t border-dashed border-[var(--border-main)] pt-8">
        {
            navLinks.length > 0 && (
                <nav class="mb-6 flex flex-wrap gap-x-6 gap-y-1" aria-label="Footer navigation">
                    {navLinks.map((link) => (
                        <a
                            class="font-sans text-xs uppercase tracking-widest opacity-60 hover:opacity-100 hover:text-[#ff5f3f] transition-colors"
                            href={link.href}
                        >
                            {link.text}
                        </a>
                    ))}
                </nav>
            )
        }
        <div
            class:list={[
                'flex flex-col gap-4',
                { 'sm:flex-row-reverse sm:items-center sm:justify-between': socialLinks.length > 0 }
            ]}
        >
            {
                socialLinks.length > 0 && (
                    <div class="flex flex-wrap gap-x-4 gap-y-1">
                        {socialLinks.map((link) => (
                            <a
                                class="inline-flex items-center justify-center text-xs uppercase tracking-widest opacity-60 hover:opacity-100 hover:text-[#ffcc55] transition-colors"
                                href={link.href}
                                target="_blank"
                                rel="noopener noreferer"
                            >
                                {link.text}
                            </a>
                        ))}
                    </div>
                )
            }
            <p class="text-xs opacity-50">
                &copy; {currentYear}
                <a class="hover:opacity-100 transition-opacity" href={import.meta.env.BASE_URL}>{siteConfig.title}</a>. All rights reserved.
            </p>
        </div>
    </div>
</footer>
