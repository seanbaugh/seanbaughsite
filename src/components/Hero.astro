---
import { marked } from 'marked';
import type { Hero as HeroProps } from '../types';
import Button from './Button.astro';
import CustomImage from './CustomImage.astro';

type Props = HeroProps & { fullBleed?: boolean };

const { title, image, text, actions, fullBleed = false } = Astro.props;
---

{
    fullBleed && image?.src ? (
        <!-- Full-bleed hero: image with overlaid title -->
        <section class="hero-fullbleed">
            <div class="hero-img-wrap">
                <CustomImage
                    class="hero-img"
                    {...image}
                    widths={[768, 1024, 1440, 1920]}
                    sizes="100vw"
                    fetchpriority="high"
                    loading="eager"
                />
                <div class="hero-overlay" />
            </div>
            <div class="hero-content">
                {title && (
                    <h1 class="hero-title">{title}</h1>
                )}
                {text && (
                    <div class="hero-text prose max-w-none" set:html={marked.parse(text)} />
                )}
                {actions && actions.length > 0 && (
                    <div class="hero-actions">
                        {actions.map((action) => (
                            <a class="hero-cta" href={action.href}>{action.text}</a>
                        ))}
                    </div>
                )}
            </div>
        </section>
    ) : (
        (title || image?.src || text || (actions && actions.length > 0)) && (
            <section class="mb-16 flex w-full flex-col gap-8 sm:mb-24">
                {title && (
                    <h1 class="font-serif text-3xl leading-tight font-medium sm:text-5xl sm:leading-tight">
                        {title}
                    </h1>
                )}
                {image?.src && (
                    <figure>
                        <CustomImage
                            class="w-full"
                            {...image}
                            widths={[480, 640, 768, 1024, 1536]}
                            sizes="(min-width: 832px) 768px, calc(100vw - 32px)"
                            fetchpriority="high"
                            loading="eager"
                        />
                        {image.caption && (
                            <figcaption class="mt-1.5 text-xs sm:text-sm">{image.caption}</figcaption>
                        )}
                    </figure>
                )}
                {text && <div class="prose sm:prose-lg max-w-none" set:html={marked.parse(text)} />}
                {actions && actions.length > 0 && (
                    <div class="flex flex-wrap gap-4">
                        {actions.map((action) => (
                            <Button href={action.href}>{action.text}</Button>
                        ))}
                    </div>
                )}
            </section>
        )
    )
}

<style>
    /* ── Full-bleed hero ── */
    .hero-fullbleed {
        position: relative;
        width: 100vw;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        margin-bottom: 4rem;
        min-height: 70vh;
        display: flex;
        align-items: flex-end;
    }

    .hero-img-wrap {
        position: absolute;
        inset: 0;
        overflow: hidden;
    }

    .hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
    }

    /* Gradient overlay: transparent top → deep navy bottom */
    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(26, 16, 64, 0.15) 0%,
            rgba(26, 16, 64, 0.55) 50%,
            rgba(26, 16, 64, 0.92) 100%
        );
    }

    .hero-content {
        position: relative;
        z-index: 2;
        width: 100%;
        max-width: 48rem;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    @media (min-width: 768px) {
        .hero-content {
            padding: 3rem 2rem 4rem;
        }
    }

    .hero-title {
        font-family: var(--font-serif, Georgia, serif);
        font-size: clamp(2.25rem, 6vw, 4.5rem);
        font-weight: 500;
        line-height: 1.1;
        color: #ffffff;
        letter-spacing: -0.02em;
        /* Gold underline accent */
        border-bottom: 2px solid #ffcc55;
        padding-bottom: 0.5rem;
        display: inline-block;
    }

    .hero-text {
        color: rgba(240, 238, 248, 0.85);
        font-size: 1.05rem;
        line-height: 1.7;
    }

    .hero-text :global(a) {
        color: #ffcc55;
        text-decoration: underline;
        text-decoration-style: dashed;
        text-underline-offset: 3px;
    }

    .hero-text :global(strong) {
        color: #ffffff;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 0.5rem;
    }

    .hero-cta {
        display: inline-flex;
        align-items: center;
        padding: 0.6rem 1.6rem;
        background: #ff5f3f;
        color: #ffffff;
        font-family: var(--font-serif, Georgia, serif);
        font-style: italic;
        font-size: 1rem;
        border-radius: 9999px;
        text-decoration: none;
        letter-spacing: 0.01em;
        transition: background 0.2s, transform 0.15s;
        border: 1px solid rgba(255,255,255,0.2);
    }

    .hero-cta:hover {
        background: #ffcc55;
        color: #1a1040;
        transform: translateY(-1px);
    }
</style>
