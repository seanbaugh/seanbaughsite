---
import siteConfig from '../data/site-config';
import CustomImage from './CustomImage.astro';

const titleClass = 'font-serif text-2xl leading-tight font-medium sm:text-3xl tracking-tight';
---

<header class="mx-auto mb-10 flex w-full max-w-3xl items-center gap-5 sm:mb-14 border-b border-dashed border-[var(--border-main)] pb-8">
    {
        siteConfig.avatar?.src && (
            <a href="/" class="shrink-0 ring-2 ring-[#ff5f3f] ring-offset-2 ring-offset-[var(--bg-main)] rounded-full transition-transform hover:scale-105">
                <CustomImage
                    class="aspect-square w-14 rounded-full object-cover sm:w-18"
                    {...siteConfig.avatar}
                    loading="eager"
                    fetchpriority="high"
                    width={80}
                    height={80}
                    widths={[80, 160]}
                    sizes="80px"
                />
            </a>
        )
    }
    <div class="grow">
        {
            siteConfig.avatar?.src ? (
                <p class={titleClass}>{siteConfig.title}</p>
            ) : (
                <a class={titleClass} href="/">
                    {siteConfig.title}
                </a>
            )
        }
        {siteConfig.subtitle && (
            <p class="text-sm leading-tight mt-0.5 opacity-60 tracking-wide">{siteConfig.subtitle}</p>
        )}
    </div>
</header>
